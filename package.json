{
  "name": "minigames",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n hub,codenames,spyfall -c auto \"npm run dev:hub\" \"npm run dev:codenames\" \"npm run dev:spyfall\"",
    "dev:hub": "npm run dev --workspace=hub",
    "dev:codenames": "npm run dev --workspace=codenames",
    "dev:spyfall": "npm run dev --workspace=spyfall",
    "smoke:routes": "node ./scripts/smoke-routes.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
