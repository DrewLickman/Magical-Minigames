{
  "name": "minigames",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n hub,codenames,spyfall,jeopardy -c auto \"npm run dev:hub\" \"npm run dev:codenames\" \"npm run dev:spyfall\" \"npm run dev:jeopardy\"",
    "dev:hub": "npm run dev --workspace=hub",
    "dev:codenames": "npm run dev --workspace=codenames",
    "dev:spyfall": "npm run dev --workspace=spyfall",
    "dev:jeopardy": "npm run dev --workspace=jeopardy",
    "dev:jeopardy:party": "npm run dev:party --workspace=jeopardy",
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "smoke:routes": "node ./scripts/smoke-routes.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
